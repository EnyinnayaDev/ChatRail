# --- Database (shared) ---
DB_HOST=localhost
DB_NAME=swiftorder
DB_USER=swiftorder
DB_PASSWORD=swiftorder
DB_PORT=5432

# Zero-setup fallback: set True to use SQLite instead of Postgres
USE_SQLITE=True

# --- Django ---
DJANGO_SECRET_KEY=dev-only-change-me
DJANGO_DEBUG=True

# --- OPay sandbox (PLACEHOLDER — confirm from OPay Business Dashboard) ---
OPAY_SANDBOX_BASE_URL=https://sandbox.opay-placeholder.example/api/v1
OPAY_MERCHANT_ID=PLACEHOLDER_MERCHANT
OPAY_PUBLIC_KEY=PLACEHOLDER_PUBLIC_KEY
OPAY_SECRET_KEY=PLACEHOLDER_SECRET_KEY
